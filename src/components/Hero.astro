---
---
<section id="inicio" class="relative min-h-screen flex items-center">
  <img
    src="/hero.jpg"
    alt="Taller metalúrgico Industrias Proba"
    class="absolute inset-0 w-full h-full object-cover"
    loading="eager"
    fetchpriority="high"
  />
  <div class="absolute inset-0 bg-hero-overlay" aria-hidden="true" />

  <div class="relative z-10 max-w-7xl mx-auto px-4 w-full">
    <div class="max-w-2xl">
      <p class="text-accent font-medium uppercase tracking-[0.3em] text-sm mb-4">
        Metalurgia de confianza
      </p>
      <h1 class="text-base-100 text-4xl md:text-6xl lg:text-7xl leading-tight mb-6">
        Soluciones en metal con <span class="text-gradient-accent">calidad</span> y compromiso
      </h1>
      <p class="text-base-100/70 text-lg md:text-xl leading-relaxed mb-10 max-w-lg">
        Más de años de experiencia en la industria metalúrgica argentina, trabajando con dedicación y cercanía.
      </p>
      <div class="flex flex-col sm:flex-row gap-4">
        <a
          href="/contacto"
          class="bg-accent hover:bg-primary text-accent-content font-semibold px-8 py-3.5 rounded transition-colors text-sm uppercase tracking-wider text-center"
        >
          Contactanos
        </a>
        <a
          href="/nosotros"
          class="border border-base-100/30 text-base-100 hover:border-accent hover:text-accent font-semibold px-8 py-3.5 rounded transition-colors text-sm uppercase tracking-wider text-center"
        >
          Conocenos
        </a>
      </div>
    </div>
  </div>
</section>
