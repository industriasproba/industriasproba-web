---
import Nav from './Nav.astro';
import Icon from './Icon.astro';

const { title } = Astro.props;
const { phone, email, address } = Astro.props;
---
<footer>
  <div>
    <p>© 2026 {title}. Todos los derechos reservados.</p>
  </div>
  <div>
    <Nav />
  </div>
  <div>
    <p><Icon />{phone}</p>
    <p><Icon />{email}</p>
    <p><Icon />{address}</p>
  </div>
</footer>
