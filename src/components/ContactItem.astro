---
import { Phone, Mail, MapPin } from '@lucide/astro';
import Link from './Link.astro';

const {
  name,
  text,
  href,
  size = 15,
  class: className = ''
} = Astro.props;

const icons = {
  phone: Phone,
  email: Mail,
  address: MapPin,
};

const IconComponent = icons[name];
---

{IconComponent && (
  <p class={`flex items-center gap-2 text-sm ${className}`}>
    <IconComponent size={size} class="flex-shrink-0 text-primary" />
    {href ? (
      <Link href={href} text={text} />
    ) : (
      <span>{text}</span>
    )}
  </p>
)}
