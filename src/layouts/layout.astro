---
import '../styles/global.css';
import '@fontsource-variable/inter';
import '@fontsource-variable/montserrat';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const { title: pageTitle } = Astro.props;
const siteName = 'Industrias Proba SA';
const title = pageTitle ? `${pageTitle} | ${siteName}` : siteName;
const phone = '+54 11 4454 7857';
const email = 'direccion@industriasproba.com.ar';
const address = 'DWB Lomas del Mirador Buenos Aires AR, Cabrera 92, B1752, Argentina';
---
<!DOCTYPE html>
<html lang="es" data-theme="light">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{title}</title>
</head>
<body>
  <Header />
  <main>
    <slot />
  </main>
  <Footer
    phone={phone}
    email={email}
    address={address}
  />
</body>
</html>

